{
	"name": "webapp",
	"description": "Build a full-stack web application with Next.js.",
	"cloudflare": {
		"label": "Next.js Framework Starter",
		"products": [
			"Workers"
		],
		"categories": [],
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/05eee9e0-2c04-48fd-11bf-84e65f839000/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/4e913a56-fd99-4372-0586-9f1364173100/preview",
		"publish": true
	},
	"dependencies": {
		"@marsidev/react-turnstile": "^1.4.2",
		"@opennextjs/cloudflare": "1.14.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"drizzle-orm": "^0.45.1",
		"lucide-react": "^0.563.0",
		"next": "16.0.7",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"tailwind-merge": "^3.4.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/postcss": "4.1.17",
		"@types/node": "24.10.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@vitest/coverage-v8": "^4.0.18",
		"baseline-browser-mapping": "^2.10.0",
		"drizzle-kit": "^0.31.9",
		"eslint": "9.39.2",
		"eslint-config-next": "16.0.7",
		"eslint-plugin-react-compiler": "^19.1.0-rc.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.3",
		"shadcn": "^3.8.4",
		"tailwindcss": "4.1.17",
		"tw-animate-css": "^1.4.0",
		"typescript": "5.9.3",
		"vitest": "^4.0.18",
		"wrangler": "4.56.0"
	},
	"engines": {
		"node": ">=22"
	},
	"private": true,
	"lint-staged": {
		"src/**/*.{ts,tsx}": [
			"eslint --fix"
		]
	},
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:ci": "eslint src/ && tsc --noEmit && vitest run && playwright test --max-failures=1",
		"test:e2e": "playwright test --max-failures=1",
		"test:e2e:ui": "playwright test --ui --max-failures=1",
		"test:e2e:headed": "playwright test --headed --max-failures=1",
		"build": "next build",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv env.d.ts",
		"check": "npm run build && tsc",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"dev": "next dev",
		"lint": "eslint src/",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"start": "next start",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply DB --local",
		"db:seed:local": "wrangler d1 execute DB --local --file=src/db/seed.sql",
		"db:studio": "drizzle-kit studio",
		"preview:uat": "opennextjs-cloudflare build && opennextjs-cloudflare preview --env uat",
		"deploy:uat": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env uat",
		"deploy:prod": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env prod",
		"db:migrate:uat": "wrangler d1 migrations apply DB --env uat --remote",
		"db:migrate:prod": "wrangler d1 migrations apply DB --env prod --remote",
		"prepare": "husky"
	}
}
