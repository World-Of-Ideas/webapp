# Environment variables for local development
# Copy this file to .dev.vars and fill in the values

# Admin password for the /admin login
ADMIN_PASSWORD=admin123

# Cloudflare Turnstile secret key (use always-pass test key for local dev)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# HMAC secret for unsubscribe tokens
UNSUBSCRIBE_SECRET=local-dev-secret

# (Optional) API key for external blog API access (POST/PUT/DELETE /api/blog)
# API_KEY=your-api-key-here

# Resend API key for email sending (optional for local dev)
RESEND_API_KEY=re_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email addresses
FROM_EMAIL=noreply@example.com
CONTACT_EMAIL=admin@example.com

# Site URL (used for links in emails, sitemaps, etc.)
SITE_URL=http://localhost:3000

# R2 public URL for serving uploaded assets
R2_PUBLIC_URL=http://localhost:3000/api/assets

# Environment identifier
ENVIRONMENT=uat

# Turnstile site key (always-pass test key for local dev, override for production)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxx

# (Optional) Site URL override for production
# NEXT_PUBLIC_SITE_URL=https://www.example.com
