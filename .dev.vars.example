# Copy this file to .dev.vars and fill in your values
# Wrangler reads .dev.vars for local development runtime variables

# Admin password for the /admin login
ADMIN_PASSWORD=admin123

# Cloudflare Turnstile secret key (always-pass test key for local dev)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# HMAC secret for unsubscribe tokens
UNSUBSCRIBE_SECRET=local-dev-secret

# Resend API key for email sending (emails won't actually send with test key)
RESEND_API_KEY=re_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email addresses
FROM_EMAIL=noreply@example.com
CONTACT_EMAIL=admin@example.com

# Site URL (used for links in emails, sitemaps, OG images — no trailing slash)
SITE_URL=http://localhost:3000

# R2 public URL for serving uploaded assets (no trailing slash)
R2_PUBLIC_URL=http://localhost:3000/api/assets

# Environment identifier
ENVIRONMENT=uat

# (Optional) API key for external blog API access (POST/PUT/DELETE /api/blog)
# API_KEY=your-api-key-here

# (Optional) Override Turnstile site key for production
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxx

# (Optional) Override site URL for production
# NEXT_PUBLIC_SITE_URL=https://www.example.com
